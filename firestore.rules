rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated users can read/write account documents
    match /accounts/{accountId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write meta docs (used for seed versioning)
    match /meta/{docId} {
      allow read, write: if request.auth != null;
    }

  }
}
