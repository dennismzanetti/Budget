rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated users can read/write account documents
    match /accounts/{accountId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write meta docs (used for seed versioning)
    match /meta/{docId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write global transactions
    match /transactions/{txnId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write global budget documents
    match /budgets/{budgetId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write categories
    match /categories/{categoryId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write their own user-scoped data
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

  }
}
